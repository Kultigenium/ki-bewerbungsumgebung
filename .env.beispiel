# Vorlage: nach `.env` kopieren und Schlüssel eintragen (.env ist gitignored).
# Kostenlosen Gemini-Schlüssel holen: https://aistudio.google.com/apikey
GEMINI_API_KEY=hier-den-schluessel-eintragen

# Optional — anderen OpenAI-kompatiblen Anbieter nutzen (z.B. Groq oder OpenRouter):
# TRIAGE_API_KEY=...
# TRIAGE_API_BASE=https://api.groq.com/openai/v1
# TRIAGE_MODEL=llama-3.3-70b-versatile
# Pause zwischen API-Aufrufen in Sekunden (Rate-Limit-Schutz, Standard 2):
# TRIAGE_DELAY=2
